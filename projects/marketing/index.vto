        aria-label="Visual agent tree interface showing hierarchical agent organization"
      >
        <img
          class="rounded-lg"
          src="/assets/tree.webp"
          alt="A screenshot of Birdhouse's agent tree"
        />
      </div>
    </div>
  </div>
</div>
</div>

<!-- FEATURE 3: SAVE WINNING PATTERNS -->
<div class="relative hero min-h-fit py-12 md:py-24 bg-base-100 overflow-hidden">
  <div
    class="relative z-10 hero-content flex-col lg:flex-row-reverse items-start gap-12 px-4 max-w-7xl w-full"
