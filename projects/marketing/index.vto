<!-- FEATURE 1: AGENT ORCHESTRATION -->
<div
  id="features"
  class="relative hero min-h-fit pt-24 pb-12 md:py-24 bg-base-100 overflow-hidden"
>
  <div
    class="relative z-10 hero-content flex-col lg:flex-row items-start gap-12 px-4 max-w-7xl w-full"
  >
    <div class="lg:w-2/5">
      <h2 class="text-5xl md:text-6xl mb-6">
        Real Agent Teams
      </h2>
      <div class="h-1 w-16 bg-primary mb-6"></div>
      <p class="text-lg text-base-content/70 mb-6 leading-relaxed font-normal">
        Humans can work together, so why can't our agents? Birdhouse allows you
        to use teams of AI agents to build software.
      </p>
      <p class="text-lg text-base-content/70 mb-8 leading-relaxed font-normal">
        Agent teams don't just work in parallel, team members can actively
        communicate and collaborate. Plus, each team member is a full-fledged
        agent you can message directly.
      </p>
    </div>

    <div class="lg:w-3/5 w-full glass p-2 md:p-12 rounded-lg">
      <div
        class="rounded-xl shadow-2xl flex items-center justify-center backdrop-blur-md bg-white/10"
        role="img"
        aria-label="Multi-agent team collaboration visualization"
      >
        <img
          class="rounded-lg"
          src="/assets/not-just-subagents.webp"
          alt="A chat message featuring agent replies"
        />
      </div>
    </div>
  </div>
</div>
</div>

<!-- Feature: Build Without Limits -->
<div class="hero min-h-fit py-12 md:py-24 bg-base-100 relative overflow-hidden">
  <div
    class="relative z-10 hero-content flex-col lg:flex-row-reverse items-start gap-12 px-4 max-w-7xl w-full"
  >
    <div class="lg:w-2/5">
      <h2 class="text-5xl md:text-6xl mb-6">
        Build Without Limits
      </h2>
      <div class="h-1 w-16 bg-primary mb-6"></div>
      <p class="text-lg text-base-content/70 mb-6 font-normal leading-relaxed">
        Birdhouse is designed with an agent-first architecture.
      </p>

      <p class="text-lg text-base-content/70 mb-6 leading-relaxed font-normal">
        Your AI agents are provided a complete shell environment and have free
        rein to make changes in your workspace. Full system access. Zero
        restrictions.
      </p>
      <p class="text-lg text-base-content/70 mb-6 leading-relaxed font-normal">
        Agents in Birdhouse don't need your approval, they just get things done.
        Use with caution!
      </p>
    </div>
    <div class="lg:w-3/5 w-full glass p-2 md:p-12 rounded-lg">
      <div class="rounded-xl shadow-2xl flex items-center justify-center">
        <img
          class="rounded-lg"
          src="/assets/without-limits.webp"
          alt="Work performed by a Birdhouse agent"
        />
      </div>
    </div>
  </div>
</div>
</div>

<!-- FEATURE 3: VISUAL AGENT TREE -->
<div class="hero min-h-fit py-12 md:py-24 bg-base-100 relative overflow-hidden">
  <div
    class="relative z-10 hero-content flex-col lg:flex-row items-start gap-12 px-4 max-w-7xl w-full"
  >
    <div class="lg:w-2/5">
